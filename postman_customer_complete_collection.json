{
      "info": {
            "_postman_id": "customer-api-collection",
            "name": "Customer API Collection",
            "description": "Complete collection for Customer Management APIs",
            "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
      },
      "item": [
            {
                  "name": "Create Customer",
                  "request": {
                        "method": "POST",
                        "header": [
                              {
                                    "key": "Content-Type",
                                    "value": "application/json"
                              },
                              {
                                    "key": "Authorization",
                                    "value": "Bearer {{auth_token}}"
                              }
                        ],
                        "body": {
                              "mode": "raw",
                              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"phone\": \"+1234567890\",\n  \"address\": \"123 Main St, City, Country\",\n  \"shopkeeperId\": \"{{shopkeeper_id}}\",\n  \"addedBy\": \"{{user_id}}\"\n}"
                        },
                        "url": {
                              "raw": "{{base_url}}/api/v1/customer/create",
                              "protocol": "{{protocol}}",
                              "host": ["{{host}}"],
                              "port": "{{port}}",
                              "path": ["api", "v1", "customer", "create"]
                        },
                        "description": "Create a new customer with all available fields"
                  },
                  "response": []
            },
            {
                  "name": "Update Customer",
                  "request": {
                        "method": "PUT",
                        "header": [
                              {
                                    "key": "Content-Type",
                                    "value": "application/json"
                              },
                              {
                                    "key": "Authorization",
                                    "value": "Bearer {{auth_token}}"
                              }
                        ],
                        "body": {
                              "mode": "raw",
                              "raw": "{\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Smith\",\n  \"email\": \"jane.smith@example.com\",\n  \"phone\": \"+0987654321\",\n  \"address\": \"456 Oak Ave, Town, Country\",\n  \"shopkeeperId\": \"{{shopkeeper_id}}\"\n}"
                        },
                        "url": {
                              "raw": "{{base_url}}/api/v1/customer/update/{{customer_id}}",
                              "protocol": "{{protocol}}",
                              "host": ["{{host}}"],
                              "port": "{{port}}",
                              "path": ["api", "v1", "customer", "update", "{{customer_id}}"]
                        },
                        "description": "Update an existing customer by ID"
                  },
                  "response": []
            },
            {
                  "name": "Delete Customer",
                  "request": {
                        "method": "DELETE",
                        "header": [
                              {
                                    "key": "Authorization",
                                    "value": "Bearer {{auth_token}}"
                              }
                        ],
                        "url": {
                              "raw": "{{base_url}}/api/v1/customer/delete/{{customer_id}}",
                              "protocol": "{{protocol}}",
                              "host": ["{{host}}"],
                              "port": "{{port}}",
                              "path": ["api", "v1", "customer", "delete", "{{customer_id}}"]
                        },
                        "description": "Delete a customer by ID"
                  },
                  "response": []
            },
            {
                  "name": "Get Customers by Shopkeeper",
                  "request": {
                        "method": "GET",
                        "header": [
                              {
                                    "key": "Authorization",
                                    "value": "Bearer {{auth_token}}"
                              }
                        ],
                        "url": {
                              "raw": "{{base_url}}/api/v1/customer/shopkeeper/{{shopkeeper_id}}",
                              "protocol": "{{protocol}}",
                              "host": ["{{host}}"],
                              "port": "{{port}}",
                              "path": ["api", "v1", "customer", "shopkeeper", "{{shopkeeper_id}}"]
                        },
                        "description": "Get all customers for a specific shopkeeper"
                  },
                  "response": []
            },
            {
                  "name": "Get All Customers",
                  "request": {
                        "method": "GET",
                        "header": [
                              {
                                    "key": "Authorization",
                                    "value": "Bearer {{auth_token}}"
                              }
                        ],
                        "url": {
                              "raw": "{{base_url}}/api/v1/customer/all",
                              "protocol": "{{protocol}}",
                              "host": ["{{host}}"],
                              "port": "{{port}}",
                              "path": ["api", "v1", "customer", "all"]
                        },
                        "description": "Get all customers (requires authentication)"
                  },
                  "response": []
            }
      ],
      "variable": [
            {
                  "key": "base_url",
                  "value": "http://localhost:3000",
                  "type": "string"
            },
            {
                  "key": "protocol",
                  "value": "http",
                  "type": "string"
            },
            {
                  "key": "host",
                  "value": "localhost",
                  "type": "string"
            },
            {
                  "key": "port",
                  "value": "3000",
                  "type": "string"
            },
            {
                  "key": "auth_token",
                  "value": "your_jwt_token_here",
                  "type": "string"
            },
            {
                  "key": "customer_id",
                  "value": "customer_object_id",
                  "type": "string"
            },
            {
                  "key": "shopkeeper_id",
                  "value": "shopkeeper_object_id",
                  "type": "string"
            },
            {
                  "key": "user_id",
                  "value": "user_object_id",
                  "type": "string"
            }
      ]
}
